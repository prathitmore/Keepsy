    android:height="128dp"
    android:viewportWidth="128"
    android:viewportHeight="128">

    <!-- Rounded Squirclish Background Card of the Brand Icon -->
    <path
        android:pathData="M 28,12 L 100,12 C 114,12 116,14 116,28 L 116,100 C 116,114 114,116 100,116 L 28,116 C 14,116 12,114 12,100 L 12,28 C 12,14 14,12 28,12 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="12"
                android:startY="12"
                android:endX="116"
                android:endY="116"
                android:type="linear">
                <item android:color="#4A5AE0" android:offset="0.0" />
                <item android:color="#323C9E" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Transformed loops & pin contents perfectly centered inside 128x128 canvas -->
