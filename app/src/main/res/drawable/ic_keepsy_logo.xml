        android:strokeLineJoin="round"
        android:fillColor="#00000000" />

    <!-- Central Teal Identifier Dot -->
    <path
        android:pathData="M 64,64 A 4,4 0 1 1 64.01,64"
        android:fillColor="#14B8A6" />
